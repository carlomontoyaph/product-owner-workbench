#!/bin/sh
# Pre-commit hook: Prevent committing secrets

# Check for .env.local (should never be committed)
if git diff --cached --name-only | grep -E "^\.env\.local$" >/dev/null; then
  echo "❌ ERROR: Attempting to commit .env.local!"
  echo "   This file contains your API keys and is in .gitignore"
  echo "   Use .env.local.example as a template instead"
  exit 1
fi

# Check for secret-looking strings in staged diffs (OpenAI, Stripe, etc.)
if git diff --cached | grep -E "sk_live_|sk_test_|sk-proj-[a-zA-Z0-9]{20,}" >/dev/null; then
  echo "❌ ERROR: Detected secret-like patterns in staged changes!"
  echo "   Found what looks like an API key (sk_live_, sk_test_, or sk-proj-...)"
  echo "   Review your changes before committing"
  exit 1
fi

exit 0
