    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "@vitest/ui": "^1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "happy-dom": "^12",
    "husky": "^9.1.7",
    "msw": "^2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^1",
    "wrangler": "^4.104.0"
